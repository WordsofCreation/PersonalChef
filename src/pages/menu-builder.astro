---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';
import {
  emptySummaryCopy,
  mainCourseOptions,
  menuBuilderSections,
  starchOptionsByCategory,
  summaryOrder,
  vegetableOptionsByCategory
} from '../data/menuBuilder';
import BuilderOptions from '../components/BuilderOptions.astro';

const pageTitle = 'Sample Menu Builder | Olympic Peninsula Personal Chef';
const pageDescription = 'Build a polished sample dinner menu with a premium, interactive menu builder designed for private chef experiences across the Olympic Peninsula.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: `https://YOUR-GITHUB-USERNAME.github.io/PersonalChef/menu-builder/`
};

const sectionLookup = Object.fromEntries(
  menuBuilderSections.map((section) => [section.id, section])
);

const dataPayload = {
  sections: menuBuilderSections,
  mainCourseOptions,
  starchOptionsByCategory,
  vegetableOptionsByCategory,
  summaryOrder,
  emptySummaryCopy,
  sectionLookup
};

const diningStyleSection = menuBuilderSections.find((section) => section.id === 'diningStyle');
const starterSection = menuBuilderSections.find((section) => section.id === 'starter');
const mainCourseCategorySection = menuBuilderSections.find((section) => section.id === 'mainCourseCategory');
const sauceSection = menuBuilderSections.find((section) => section.id === 'sauce');
const starchCategorySection = menuBuilderSections.find((section) => section.id === 'starchCategory');
const vegetableCategorySection = menuBuilderSections.find((section) => section.id === 'vegetableCategory');
const additionsSection = menuBuilderSections.find((section) => section.id === 'optionalAdditions');
const dessertSection = menuBuilderSections.find((section) => section.id === 'dessert');

const defaultMainCourseCategory = mainCourseCategorySection?.options?.[0]?.value ?? 'seafood';
const initialMainCourseOptions = mainCourseOptions[defaultMainCourseCategory] ?? [];

---
<BaseLayout title={pageTitle} description={pageDescription} path="/menu-builder" schema={schema}>
  <section class="section menu-builder-hero-section">
    <div class="container menu-builder-shell">
      <div class="menu-builder-intro panel">
        <p class="eyebrow">Sample menu builder</p>
        <h1>Shape a sample dinner that already feels thoughtfully hosted.</h1>
        <p>
          Explore a polished first version of the menu planning experience. Select a dining style, build your courses,
          and watch the menu summary evolve into a refined Olympic Peninsula concept for your table.
        </p>
        <div class="menu-builder-hero-points">
          <div>
            <strong>Curated, not cluttered</strong>
            <span>Every option is shaped around Pacific Northwest ingredients, seasonal rhythm, and premium private-chef service.</span>
          </div>
          <div>
            <strong>Ready for future expansion</strong>
            <span>Built to support menu previews, inquiry handoff, larger culinary datasets, and pairing logic in later phases.</span>
          </div>
        </div>
        <div class="menu-builder-hero-actions">
          <a class="btn btn-secondary" href={withBase('/sample-menus')}>Browse Sample Menus</a>
          <a class="btn btn-primary" href="#menu-builder-form">Start Building</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container menu-builder-layout" id="menu-builder-form">
      <form class="menu-builder-form" data-menu-builder novalidate>
        <div class="menu-builder-grid">
          <section class="panel builder-section" aria-labelledby="dining-style-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 1</p>
              <h2 id="dining-style-heading">{diningStyleSection?.title}</h2>
              <p>{diningStyleSection?.helper}</p>
            </div>
            <div class="builder-option-grid">
              {diningStyleSection?.options && <BuilderOptions sectionId="diningStyle" options={diningStyleSection.options} type="single" />}
            </div>
          </section>

          <section class="panel builder-section" aria-labelledby="starter-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 2</p>
              <h2 id="starter-heading">{starterSection?.title}</h2>
              <p>{starterSection?.helper}</p>
            </div>
            <div class="builder-option-grid builder-option-grid--compact">
              {starterSection?.options && <BuilderOptions sectionId="starter" options={starterSection.options} type="single" />}
            </div>
          </section>

          <section class="panel builder-section" aria-labelledby="main-course-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 3</p>
              <h2 id="main-course-heading">Main Course</h2>
              <p>Choose a category first, then refine it into a featured entrée.</p>
            </div>

            <div class="builder-subsection">
              <div class="builder-subsection-head">
                <h3>{mainCourseCategorySection?.title}</h3>
                <p>{mainCourseCategorySection?.helper}</p>
              </div>
              <div class="builder-option-grid builder-option-grid--compact">
                {mainCourseCategorySection?.options && <BuilderOptions sectionId="mainCourseCategory" options={mainCourseCategorySection.options} type="single" />}
              </div>
            </div>

            <div class="builder-subsection">
              <div class="builder-subsection-head">
                <h3>Main Course Selection</h3>
                <p>Available entrées update based on your chosen category, with subtle chef-curated pairing guidance where helpful.</p>
              </div>
              <div class="builder-option-grid builder-option-grid--compact" data-main-course-options>
                <BuilderOptions sectionId="mainCourseSelection" options={initialMainCourseOptions} type="single" />
              </div>
              <p class="builder-inline-note" data-main-course-helper>
                Select a category above to view curated entrée options.
              </p>
            </div>
          </section>

          <section class="panel builder-section" aria-labelledby="plate-details-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 4</p>
              <h2 id="plate-details-heading">Plate Details</h2>
              <p>Compose the supporting elements that make the entrée feel complete.</p>
            </div>
            <div class="builder-multi-column">
              <div class="builder-subsection">
                <div class="builder-subsection-head">
                  <h3>{sauceSection?.title}</h3>
                  <p>{sauceSection?.helper}</p>
                </div>
                <div class="builder-option-grid builder-option-grid--compact">
                  {sauceSection?.options && <BuilderOptions sectionId="sauce" options={sauceSection.options} type="single" />}
                </div>
              </div>
              <div class="builder-subsection builder-subsection--stacked">
                <div class="builder-subsection-head">
                  <h3>Starch / Grain</h3>
                  <p>Choose a starch category first, then refine it into the specific accompaniment.</p>
                </div>
                <div class="builder-nested-flow">
                  <div class="builder-nested-panel">
                    <div class="builder-subsection-head">
                      <h4>{starchCategorySection?.title}</h4>
                      <p>{starchCategorySection?.helper}</p>
                    </div>
                    <div class="builder-option-grid builder-option-grid--compact">
                      {starchCategorySection?.options && <BuilderOptions sectionId="starchCategory" options={starchCategorySection.options} type="single" />}
                    </div>
                  </div>
                  <div class="builder-nested-panel">
                    <div class="builder-subsection-head">
                      <h4>Starch / Grain Selection</h4>
                      <p>Available starches update based on the category you choose.</p>
                    </div>
                    <div class="builder-option-grid builder-option-grid--compact" data-starch-options></div>
                    <p class="builder-inline-note" data-starch-helper>Select a starch category above to view curated options.</p>
                  </div>
                </div>
              </div>
              <div class="builder-subsection builder-subsection--stacked">
                <div class="builder-subsection-head">
                  <h3>Vegetables</h3>
                  <p>Choose a vegetable category first, then select the accompaniment that best balances the plate.</p>
                </div>
                <div class="builder-nested-flow">
                  <div class="builder-nested-panel">
                    <div class="builder-subsection-head">
                      <h4>{vegetableCategorySection?.title}</h4>
                      <p>{vegetableCategorySection?.helper}</p>
                    </div>
                    <div class="builder-option-grid builder-option-grid--compact">
                      {vegetableCategorySection?.options && <BuilderOptions sectionId="vegetableCategory" options={vegetableCategorySection.options} type="single" />}
                    </div>
                  </div>
                  <div class="builder-nested-panel">
                    <div class="builder-subsection-head">
                      <h4>Vegetable Selection</h4>
                      <p>Vegetable accompaniments respond to the category you choose while keeping the builder clean and easy to scan.</p>
                    </div>
                    <div class="builder-option-grid builder-option-grid--compact" data-vegetable-options></div>
                    <p class="builder-inline-note" data-vegetable-helper>Select a vegetable category above to view curated options.</p>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="panel builder-section" aria-labelledby="finishing-touches-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 5</p>
              <h2 id="finishing-touches-heading">Finishing Touches</h2>
              <p>Add optional hosting details and a final dessert course.</p>
            </div>
            <div class="builder-multi-column builder-multi-column--wide">
              <div class="builder-subsection">
                <div class="builder-subsection-head">
                  <h3>{additionsSection?.title}</h3>
                  <p>{additionsSection?.helper}</p>
                </div>
                <div class="builder-option-grid builder-option-grid--compact">
                  {additionsSection?.options && <BuilderOptions sectionId="optionalAdditions" options={additionsSection.options} type="multiple" />}
                </div>
              </div>
              <div class="builder-subsection">
                <div class="builder-subsection-head">
                  <h3>{dessertSection?.title}</h3>
                  <p>{dessertSection?.helper}</p>
                </div>
                <div class="builder-option-grid builder-option-grid--compact">
                  {dessertSection?.options && <BuilderOptions sectionId="dessert" options={dessertSection.options} type="single" />}
                </div>
              </div>
            </div>
          </section>

          <section class="panel builder-section" aria-labelledby="custom-considerations-heading">
            <div class="builder-section-head">
              <p class="eyebrow">Step 6</p>
              <h2 id="custom-considerations-heading">Custom Considerations</h2>
              <p>Share allergies, favorite ingredients, dietary preferences, celebration notes, or anything special you would love included.</p>
            </div>
            <label class="builder-textarea-wrap" for="custom-considerations">
              <span class="builder-label">What should the chef know to personalize this menu?</span>
              <textarea
                id="custom-considerations"
                name="customConsiderations"
                rows="6"
                maxlength="600"
                placeholder="Examples: shellfish allergy, favorite local seafood, dairy-light menu, anniversary dessert moment, wellness focus, or a wine-friendly direction."
                data-builder-textarea
              ></textarea>
              <span class="builder-helper-text">This stays in page state for now and helps shape future inquiry and menu-planning features.</span>
            </label>
          </section>

          <div class="panel builder-cta-panel">
            <div>
              <p class="eyebrow">Preview-ready flow</p>
              <h2>See your selections presented like a composed private-chef menu.</h2>
              <p>When you’re ready, move from the builder into a polished preview page without losing your selections.</p>
            </div>
            <button class="btn btn-primary builder-preview-button" type="button" data-preview-button>
              Preview My Menu
            </button>
          </div>
        </div>
      </form>

      <aside class="panel menu-summary-panel" aria-labelledby="menu-summary-heading">
        <div class="menu-summary-shell">
          <div class="menu-summary-head">
            <p class="eyebrow">Live summary</p>
            <h2 id="menu-summary-heading">Your sample menu</h2>
            <p>A curated snapshot of your Pacific Northwest dinner as it takes shape.</p>
          </div>

          <div class="menu-summary-empty" data-summary-empty>
            <strong>{emptySummaryCopy.title}</strong>
            <p>{emptySummaryCopy.description}</p>
          </div>

          <div class="menu-summary-course-list" data-summary-list hidden></div>

          <div class="menu-summary-notes">
            <p class="menu-summary-notes-label">Chef notes</p>
            <p data-summary-considerations>
              No custom considerations yet. Use the notes field to mention dietary needs, event tone, or ingredient preferences.
            </p>
          </div>

          <div class="menu-summary-footer">
            <span>Designed for a premium, static-site friendly planning flow on GitHub Pages.</span>
            <a href={withBase('/contact')}>Inquire about a custom dinner</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script type="application/json" id="menu-builder-data" set:html={JSON.stringify(dataPayload)}></script>
  <script>
    import {
      MENU_BUILDER_STORAGE_KEY,
      createEmptyMenuBuilderState,
      getOptionLabel,
      readBuilderState,
      summaryLabels,
      writeBuilderState
    } from '../utils/menuBuilderClient';
    import { withBase } from '../utils/paths';

    const dataElement = document.getElementById('menu-builder-data');

    if (dataElement?.textContent) {
      const builderData = JSON.parse(dataElement.textContent);
      const summaryList = document.querySelector('[data-summary-list]');
      const summaryEmpty = document.querySelector('[data-summary-empty]');
      const summaryConsiderations = document.querySelector('[data-summary-considerations]');
      const mainCourseContainer = document.querySelector('[data-main-course-options]');
      const mainCourseHelper = document.querySelector('[data-main-course-helper]');
      const starchContainer = document.querySelector('[data-starch-options]');
      const starchHelper = document.querySelector('[data-starch-helper]');
      const vegetableContainer = document.querySelector('[data-vegetable-options]');
      const vegetableHelper = document.querySelector('[data-vegetable-helper]');
      const previewButton = document.querySelector('[data-preview-button]');
      const form = document.querySelector('[data-menu-builder]');
      const textarea = document.querySelector('[data-builder-textarea]');
      const state = readBuilderState() || createEmptyMenuBuilderState();

      const renderDependentOptions = ({
        container,
        helper,
        categoryValue,
        categorySectionId,
        selectionSectionId,
        selectedValue,
        collection,
        emptyTitle,
        emptyCopy,
        helperWhenEmpty,
        helperWhenFilled
      }) => {
        if (!container) return;

        const options = collection[categoryValue] || [];

        if (!categoryValue || options.length === 0) {
          container.innerHTML = `
            <div class="builder-empty-state">
              <strong>${emptyTitle}</strong>
              <p>${emptyCopy}</p>
            </div>
          `;
          if (helper) helper.textContent = helperWhenEmpty;
          return;
        }

        container.innerHTML = options.map((option) => `
          <label class="builder-option" for="${selectionSectionId}-${option.value}" data-option-card data-section="${selectionSectionId}" data-value="${option.value}">
            <input
              id="${selectionSectionId}-${option.value}"
              class="builder-option-input"
              type="radio"
              name="${selectionSectionId}"
              value="${option.value}"
              data-builder-input
              data-section="${selectionSectionId}"
              ${selectedValue === option.value ? 'checked' : ''}
            />
            <span class="builder-option-check" aria-hidden="true"></span>
            <span class="builder-option-copy">
              <strong>${option.label}</strong>
              <span>${option.description || ''}</span>
              ${option.note ? `<small class="builder-option-note">${option.note}</small>` : ''}
            </span>
          </label>
        `).join('');

        if (helper) {
          const categoryLabel = getOptionLabel(builderData, state, categorySectionId, categoryValue);
          helper.textContent = helperWhenFilled(categoryLabel);
        }
      };

      const hydrateForm = () => {
        Object.entries(state).forEach(([sectionId, value]) => {
          if (sectionId === 'customConsiderations') {
            if (textarea instanceof HTMLTextAreaElement) textarea.value = value;
            return;
          }

          if ((sectionId === 'optionalAdditions' || sectionId === 'vegetableSelections') && Array.isArray(value)) {
            value.forEach((selectedValue) => {
              const input = document.querySelector(`input[name="${sectionId === 'vegetableSelections' ? 'vegetableSelection' : 'optionalAdditions'}"][value="${selectedValue}"]`);
              if (input instanceof HTMLInputElement) input.checked = true;
            });
            return;
          }

          if (typeof value === 'string' && value) {
            const input = document.querySelector(`input[name="${sectionId}"][value="${value}"]`);
            if (input instanceof HTMLInputElement) input.checked = true;
          }
        });
      };

      const persistState = () => {
        writeBuilderState(state);
      };

      const renderMainCourseOptions = () => {
        const category = state.mainCourseCategory;
        const options = builderData.mainCourseOptions[category] || [];

        if (!mainCourseContainer) return;

        if (!category || options.length === 0) {
          mainCourseContainer.innerHTML = `
            <div class="builder-empty-state">
              <strong>Select a main course category</strong>
              <p>Once you choose a main course style, matching entrées for that Pacific Northwest direction will appear here.</p>
            </div>
          `;
          if (mainCourseHelper) {
            mainCourseHelper.textContent = 'Choose a main course style to unlock curated entrée selections.';
          }
          return;
        }

        mainCourseContainer.innerHTML = options.map((option) => `
          <label class="builder-option" for="mainCourseSelection-${option.value}" data-option-card data-section="mainCourseSelection" data-value="${option.value}">
            <input
              id="mainCourseSelection-${option.value}"
              class="builder-option-input"
              type="radio"
              name="mainCourseSelection"
              value="${option.value}"
              data-builder-input
              data-section="mainCourseSelection"
              ${state.mainCourseSelection === option.value ? 'checked' : ''}
            />
            <span class="builder-option-check" aria-hidden="true"></span>
            <span class="builder-option-copy">
              <strong>${option.label}</strong>
              <span>${option.description || ''}</span>
              ${option.note ? `<small class="builder-option-note">${option.note}</small>` : ''}
            </span>
          </label>
        `).join('');

        if (mainCourseHelper) {
          const categoryLabel = getOptionLabel(builderData, state, 'mainCourseCategory', category);
          mainCourseHelper.textContent = `${categoryLabel} entrées ready to refine your menu.`;
        }
      };

      const renderStarchOptions = () => {
        renderDependentOptions({
          container: starchContainer,
          helper: starchHelper,
          categoryValue: state.starchCategory,
          categorySectionId: 'starchCategory',
          selectionSectionId: 'starchSelection',
          selectedValue: state.starchSelection,
          collection: builderData.starchOptionsByCategory,
          emptyTitle: 'Select a starch category',
          emptyCopy: 'Choose a starch direction first and the matching starches or grains will appear here.',
          helperWhenEmpty: 'Choose a starch category to unlock curated starch and grain selections.',
          helperWhenFilled: (categoryLabel) => `${categoryLabel} selections ready to complete the plate.`
        });
      };

      const renderVegetableOptions = () => {
        renderDependentOptions({
          container: vegetableContainer,
          helper: vegetableHelper,
          categoryValue: state.vegetableCategory,
          categorySectionId: 'vegetableCategory',
          selectionSectionId: 'vegetableSelection',
          selectedValue: state.vegetableSelections[0] || '',
          collection: builderData.vegetableOptionsByCategory,
          emptyTitle: 'Select a vegetable category',
          emptyCopy: 'Choose a vegetable direction first and the matching accompaniments will appear here.',
          helperWhenEmpty: 'Choose a vegetable category to unlock curated accompaniments.',
          helperWhenFilled: (categoryLabel) => `${categoryLabel} accompaniments ready to balance the plate.`
        });
      };

      const renderSummary = () => {
        const vegetableLabels = state.vegetableSelections
          .map((value) => getOptionLabel(builderData, state, 'vegetableSelection', value))
          .filter(Boolean);

        const summaryItems = [
          state.diningStyle ? {
            label: summaryLabels.diningStyle,
            value: getOptionLabel(builderData, state, 'diningStyle', state.diningStyle)
          } : null,
          state.starter ? {
            label: summaryLabels.starter,
            value: getOptionLabel(builderData, state, 'starter', state.starter)
          } : null,
          state.mainCourseCategory ? {
            label: summaryLabels.mainCourseCategory,
            value: getOptionLabel(builderData, state, 'mainCourseCategory', state.mainCourseCategory)
          } : null,
          state.mainCourseSelection ? {
            label: summaryLabels.mainCourseSelection,
            value: getOptionLabel(builderData, state, 'mainCourseSelection', state.mainCourseSelection)
          } : null,
          state.sauce ? {
            label: summaryLabels.sauce,
            value: getOptionLabel(builderData, state, 'sauce', state.sauce)
          } : null,
          state.starchSelection ? {
            label: 'Starch / Grain',
            value: getOptionLabel(builderData, state, 'starchSelection', state.starchSelection),
            meta: getOptionLabel(builderData, state, 'starchCategory', state.starchCategory)
          } : null,
          vegetableLabels.length ? {
            label: 'Vegetables',
            value: vegetableLabels.join(' · '),
            meta: getOptionLabel(builderData, state, 'vegetableCategory', state.vegetableCategory)
          } : null,
          state.optionalAdditions.length ? {
            label: summaryLabels.optionalAdditions,
            value: state.optionalAdditions
              .map((value) => getOptionLabel(builderData, state, 'optionalAdditions', value))
              .filter(Boolean)
              .join(' · ')
          } : null,
          state.dessert ? {
            label: summaryLabels.dessert,
            value: getOptionLabel(builderData, state, 'dessert', state.dessert)
          } : null,
          state.customConsiderations.trim() ? {
            label: summaryLabels.customConsiderations,
            value: state.customConsiderations.trim()
          } : null
        ].filter(Boolean);

        if (!summaryList || !summaryEmpty) return;

        if (summaryItems.length === 0) {
          summaryEmpty.hidden = false;
          summaryList.hidden = true;
          summaryList.innerHTML = '';
        } else {
          summaryEmpty.hidden = true;
          summaryList.hidden = false;
          summaryList.innerHTML = summaryItems.map((item) => `
            <article class="menu-summary-item">
              <p>${item.label}</p>
              <strong>${item.value}</strong>
              ${item.meta ? `<span class="menu-summary-item-meta">${item.meta}</span>` : ''}
            </article>
          `).join('');
        }

        if (summaryConsiderations) {
          summaryConsiderations.textContent = state.customConsiderations.trim()
            ? state.customConsiderations.trim()
            : 'No custom considerations yet. Use the notes field to mention allergies, celebration details, favorite ingredients, or dietary preferences.';
        }
      };
      const syncCardStates = () => {
        document.querySelectorAll('[data-option-card]').forEach((card) => {
          const section = card.getAttribute('data-section');
          const value = card.getAttribute('data-value');
          const isMultiple = section === 'optionalAdditions' || section === 'vegetableSelection';
          const active = section === 'optionalAdditions'
            ? state.optionalAdditions.includes(value)
            : section === 'vegetableSelection'
              ? state.vegetableSelections.includes(value)
              : state[section] === value;
          card.classList.toggle('is-selected', Boolean(active));
        });
      };

      form?.addEventListener('change', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;

        const sectionId = target.dataset.section;
        if (!sectionId) return;

        if (sectionId === 'optionalAdditions') {
          state.optionalAdditions = Array.from(document.querySelectorAll('input[name="optionalAdditions"]:checked'))
            .map((input) => input instanceof HTMLInputElement ? input.value : '')
            .filter(Boolean);
        } else if (sectionId === 'vegetableSelection') {
          state.vegetableSelections = target.checked ? [target.value] : [];
        } else {
          state[sectionId] = target.value;
        }

        if (sectionId === 'mainCourseCategory') {
          state.mainCourseSelection = '';
          renderMainCourseOptions();
        }

        if (sectionId === 'starchCategory') {
          state.starchSelection = '';
          renderStarchOptions();
        }

        if (sectionId === 'vegetableCategory') {
          state.vegetableSelections = [];
          renderVegetableOptions();
        }

        persistState();
        syncCardStates();
        renderSummary();
      });

      textarea?.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLTextAreaElement)) return;
        state.customConsiderations = target.value;
        persistState();
        renderSummary();
      });

      previewButton?.addEventListener('click', () => {
        persistState();
        window.location.href = withBase('/menu-preview');
      });

      if (!sessionStorage.getItem(MENU_BUILDER_STORAGE_KEY)) {
        persistState();
      }

      renderMainCourseOptions();
      renderStarchOptions();
      renderVegetableOptions();
      hydrateForm();
      syncCardStates();
      renderSummary();
    }
  </script>
</BaseLayout>
