---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Book a Personal Chef',
  mainEntity: { '@type': 'LocalBusiness', name: 'Olympic Peninsula Personal Chef' }
};
---
<BaseLayout title="Book a Personal Chef | Port Angeles, Sequim & Olympic Peninsula" description="Request a custom proposal for private dining, meal prep, and vacation rental chef services in Port Angeles, Sequim, and across the Olympic Peninsula." path="/contact" schema={schema}>
  <section class="section inquiry-section">
    <div class="container local-grid inquiry-layout">
      <div class="card-stack inquiry-sidebar">
        <div class="inquiry-heading-block">
          <p class="eyebrow">Request your custom proposal</p>
          <h1>Share a few thoughtful details, and we’ll shape a chef experience that feels polished from the very first reply.</h1>
          <p class="inquiry-intro-text">For private dinners, weekly meal prep, and vacation rental service across the Olympic Peninsula, every inquiry is reviewed with care and answered with a tailored recommendation.</p>
        </div>

        <div class="card inquiry-intro-card">
          <div class="inquiry-intro-copy">
            <p class="inquiry-lead">Expect a custom proposal, clear next steps, and availability guidance within one business day whenever possible.</p>
            <p>Allergy-aware, wellness-focused, pescatarian, gluten-free, dairy-free, and family-specific requests are always welcome.</p>
          </div>
          <div class="inquiry-pill-list" aria-label="Why clients choose this inquiry process">
            <span>Custom menus</span>
            <span>Discreet hospitality</span>
            <span>Prompt follow-up</span>
          </div>
        </div>
      </div>

      <div class="card inquiry-form-shell">
        <div class="inquiry-form-ornament" aria-hidden="true"></div>
        <div class="inquiry-form-shell-inner">
          <div class="inquiry-form-header">
            <div>
              <p class="eyebrow">Request your custom proposal</p>
              <h2>A polished booking experience starts here.</h2>
              <p>Tell us about your date, setting, and preferences, and we’ll prepare a custom proposal shaped around the experience you want to host.</p>
            </div>
            <div class="soft-panel inquiry-process" aria-label="What happens next">
              <p class="process-kicker">What happens next</p>
              <ol class="process-list">
                <li><strong>Share your details</strong><span>Tell us the essentials so we can understand your date, setting, and priorities.</span></li>
                <li><strong>Receive a tailored proposal</strong><span>We’ll recommend the right service format, menu direction, and pricing guidance.</span></li>
                <li><strong>Finalize your menu and date</strong><span>Once the fit feels right, we’ll refine the experience and confirm your booking.</span></li>
              </ol>
            </div>
          </div>

          <div class="form-alert form-alert-success" id="formSuccess" role="status" aria-live="polite" tabindex="-1" hidden>
            <div class="form-alert-icon" aria-hidden="true">✓</div>
            <div class="form-alert-content">
              <p class="form-alert-kicker">Inquiry received</p>
              <strong>Thank you — your custom proposal request is in.</strong>
              <span>We’ll review your details and follow up soon with menu direction, availability guidance, and thoughtful next steps.</span>
            </div>
          </div>

          <div class="form-alert form-alert-error" id="formError" role="alert" aria-live="assertive" tabindex="-1" hidden>
            <div class="form-alert-icon" aria-hidden="true">!</div>
            <div>
              <strong>Please review your inquiry.</strong>
              <span class="form-alert-message"></span>
            </div>
          </div>

          <form class="form-grid premium-form" id="bookingForm" method="post" action="https://api.web3forms.com/submit" novalidate>
            <input type="hidden" name="access_key" value="9ed3578c-0218-46a9-ac21-0c381dac9e67" />
            <input type="hidden" name="subject" value="New Personal Chef Inquiry" />
            <input type="hidden" name="from_name" value="PNW Personal Chef Website" />
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="sr-only" aria-hidden="true" />
            <div class="full-span form-section-label">
              <p>Your details</p>
            </div>
            <div class="field-group">
              <label for="name">Full Name <span class="field-required">Required</span></label>
              <input id="name" type="text" name="name" autocomplete="name" placeholder="Your full name" required aria-describedby="error-name" />
              <p class="field-error" id="error-name" aria-live="polite"></p>
            </div>

            <div class="field-group">
              <label for="email">Email Address <span class="field-required">Required</span></label>
              <input id="email" type="email" name="email" autocomplete="email" placeholder="you@example.com" required aria-describedby="error-email" />
              <p class="field-error" id="error-email" aria-live="polite"></p>
            </div>

            <div class="field-group">
              <label for="phone">Phone Number</label>
              <input id="phone" type="tel" name="phone" autocomplete="tel" placeholder="(360) 555-0123" aria-describedby="error-phone" />
              <p class="field-error" id="error-phone" aria-live="polite"></p>
            </div>

            <div class="field-group field-group-select">
              <label for="service">Service Type <span class="field-required">Required</span></label>
              <select id="service" name="service" required aria-describedby="error-service">
                <option value="">Select a service</option>
                <option>Weekly Meal Prep</option>
                <option>Private Dinner</option>
                <option>Vacation Rental Chef Service</option>
                <option>Small Event Catering</option>
                <option>Holiday Meal</option>
                <option>Custom Dietary Menu</option>
              </select>
              <p class="field-error" id="error-service" aria-live="polite"></p>
            </div>

            <div class="full-span form-section-label form-section-label-planning">
              <p>Event planning details</p>
            </div>

            <div class="field-group">
              <label for="guestCount">Guest Count</label>
              <input id="guestCount" type="number" name="guestCount" min="1" inputmode="numeric" placeholder="2, 8, 20…" aria-describedby="error-guestCount" />
              <p class="field-error" id="error-guestCount" aria-live="polite"></p>
            </div>

            <div class="field-group field-group-date">
              <label for="eventDate">Preferred Date</label>
              <input id="eventDate" type="date" name="eventDate" aria-describedby="error-eventDate" />
              <p class="field-error" id="error-eventDate" aria-live="polite"></p>
            </div>

            <div class="field-group">
              <label for="location">Location</label>
              <input id="location" type="text" name="location" placeholder="Port Angeles, Sequim, or your Olympic Peninsula property" aria-describedby="error-location" />
              <p class="field-error" id="error-location" aria-live="polite"></p>
            </div>

            <div class="field-group">
              <label for="budget">Budget Range</label>
              <input id="budget" type="text" name="budget" placeholder="$500–$1,000, $1,500+, or preferred range" aria-describedby="error-budget" />
              <p class="field-error" id="error-budget" aria-live="polite"></p>
            </div>

            <div class="field-group field-group-wide">
              <label for="dietaryNeeds">Dietary Needs</label>
              <input id="dietaryNeeds" type="text" name="dietaryNeeds" placeholder="Allergies, preferences, wellness goals, family needs" aria-describedby="error-dietaryNeeds" />
              <p class="field-error" id="error-dietaryNeeds" aria-live="polite"></p>
            </div>

            <div class="field-group field-group-wide">
              <label for="message">Message / Tell us about your event <span class="field-required">Required</span></label>
              <textarea id="message" name="message" placeholder="Share the occasion, atmosphere, menu style, service expectations, and any details that will help us prepare a thoughtful proposal." required aria-describedby="messageHint error-message"></textarea>
              <div class="field-meta">
                <p class="field-hint" id="messageHint">A strong overview is enough for us to recommend the right service format, menu direction, and next steps.</p>
                <p class="field-error" id="error-message" aria-live="polite"></p>
              </div>
            </div>

            <div class="full-span inquiry-submit-row">
              <div class="form-note inquiry-form-note">
                <p class="submit-overline">Request Your Custom Proposal</p>
                <h3>Ready when you are.</h3>
                <p>Submit your details for a tailored recommendation, pricing guidance, and next steps aligned with your date and service style.</p>
              </div>
              <button class="btn btn-primary premium-submit" type="submit" id="submitButton">
                <span class="submit-label">Request Your Custom Proposal</span>
                <span class="submit-spinner" aria-hidden="true"></span>
              </button>
              <p class="submit-reassurance">Private inquiry • No obligation • Thoughtful follow-up within one business day whenever possible.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector('#bookingForm');
    const submitButton = document.querySelector('#submitButton');
    const submitLabel = submitButton?.querySelector('.submit-label');
    const successPanel = document.querySelector('#formSuccess');
    const errorPanel = document.querySelector('#formError');
    const errorPanelMessage = errorPanel?.querySelector('.form-alert-message');
    const fieldErrorElements = Array.from(document.querySelectorAll('.field-error'));

    const fieldNames = ['name', 'email', 'phone', 'service', 'guestCount', 'eventDate', 'location', 'dietaryNeeds', 'budget', 'message'];

    const resetErrors = () => {
      errorPanel.hidden = true;
      if (errorPanelMessage) errorPanelMessage.textContent = '';
      fieldErrorElements.forEach((element) => {
        element.textContent = '';
      });
      fieldNames.forEach((name) => {
        const field = form?.elements.namedItem(name);
        if (field instanceof HTMLElement) {
          field.removeAttribute('aria-invalid');
        }
      });
    };

    const setSubmitting = (isSubmitting) => {
      if (!submitButton || !submitLabel) return;
      submitButton.disabled = isSubmitting;
      submitButton.setAttribute('aria-busy', String(isSubmitting));
      submitLabel.textContent = isSubmitting ? 'Sending Your Inquiry…' : 'Request Your Custom Proposal';
    };

    const setFieldError = (name, message) => {
      const errorElement = document.querySelector(`#error-${name}`);
      const field = form?.elements.namedItem(name);
      if (errorElement) {
        errorElement.textContent = message;
      }
      if (field instanceof HTMLElement) {
        field.setAttribute('aria-invalid', 'true');
      }
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      resetErrors();
      successPanel.hidden = true;
      form.hidden = false;
      form.closest('.inquiry-form-shell-inner')?.classList.remove('is-success');

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      setSubmitting(true);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json'
          }
        });

        const data = await response.json().catch(() => ({}));

        if (response.ok) {
          form.reset();
          successPanel.hidden = false;
          form.hidden = true;
          form.closest('.inquiry-form-shell-inner')?.classList.add('is-success');
          successPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          successPanel.focus();
          return;
        }

        if (Array.isArray(data?.errors) && data.errors.length > 0) {
          const unmappedMessages = [];

          data.errors.forEach((error) => {
            const fieldName = typeof error?.field === 'string' ? error.field : typeof error?.path === 'string' ? error.path : '';
            if (fieldName) {
              setFieldError(fieldName, error.message || 'Please review this field.');
            } else if (error?.message) {
              unmappedMessages.push(error.message);
            }
          });

          if (errorPanelMessage) {
            errorPanelMessage.textContent = unmappedMessages[0] || 'We were unable to send your inquiry just now. Please review the highlighted fields and try again.';
          }
        } else if (errorPanelMessage) {
          errorPanelMessage.textContent = data?.message || 'We were unable to send your inquiry just now. Please try again in a moment.';
        }

        errorPanel.hidden = false;
        errorPanel.focus();
      } catch (error) {
        if (errorPanelMessage) {
          errorPanelMessage.textContent = 'A connection issue interrupted your inquiry. Please try again in a moment.';
        }
        errorPanel.hidden = false;
        errorPanel.focus();
      } finally {
        setSubmitting(false);
      }
    });
  </script>
</BaseLayout>
