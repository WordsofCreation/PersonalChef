---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqList from '../components/FaqList.astro';
import CTA from '../components/CTA.astro';
const faqs = await getCollection('faqs');
const schema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.data.question, acceptedAnswer: { '@type': 'Answer', text: faq.data.answer } })) };
---
<BaseLayout title="FAQ | Personal Chef Port Angeles, Sequim & Olympic Peninsula" description="Common questions about booking a personal chef in Port Angeles or Sequim, custom pricing, dietary accommodations, and service across the Olympic Peninsula." path="/faq" schema={schema}>
  <section class="section">
    <div class="container split-intro">
      <div class="section-header" style="margin-bottom:0;">
        <p class="eyebrow">FAQ</p>
        <h1>Clear answers for planning chef service on the Olympic Peninsula.</h1>
        <p>These are the questions clients most often ask before booking private dining, meal prep, vacation rental service, and intimate events in Port Angeles, Sequim, and nearby communities.</p>
      </div>
      <div class="card schema-note">
        <p><strong>Helpful note:</strong> Pricing is typically shared after a short inquiry so menus, dietary needs, travel, and the desired level of service can be quoted accurately.</p>
      </div>
    </div>
    <div class="container" style="margin-top:2rem;">
      <FaqList faqs={faqs} />
    </div>
  </section>
  <CTA title="Still deciding what kind of chef service is right for you?" text="Use the inquiry form to share a few details and receive guidance on fit, timing, menu style, and a custom quote." secondaryHref="/contact" secondaryLabel="Contact the Chef" />
</BaseLayout>
