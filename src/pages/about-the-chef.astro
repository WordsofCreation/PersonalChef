---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chef Placeholder Name',
  jobTitle: 'Personal Chef',
  worksFor: { '@type': 'LocalBusiness', name: 'Olympic Peninsula Personal Chef' },
  address: { '@type': 'PostalAddress', addressLocality: 'Port Angeles', addressRegion: 'WA' },
  description: 'Personal chef serving Port Angeles and the Olympic Peninsula with meal prep, private dining, and custom menus.'
};
---
<BaseLayout title="About the Chef | Olympic Peninsula Personal Chef" description="Meet the chef behind this Port Angeles and Sequim personal chef service, focused on seasonal ingredients, custom menus, polished hospitality, and a calm client experience." path="/about-the-chef" schema={schema}>
  <section class="section">
    <div class="container grid two-col">
      <div class="card">
        <p class="eyebrow">About the chef</p>
        <h1>A hospitality-led culinary approach grounded in trust, seasonality, and thoughtful service.</h1>
        <p>Chef Placeholder Name brings a refined but approachable perspective to private dining and meal support on the Olympic Peninsula, blending menu intuition, polished execution, and the kind of calm presence that helps a home feel instantly cared for.</p>
        <p>The focus is always on ingredient quality, attentive planning, and a guest experience that feels personal rather than performative—whether serving a romantic dinner in Port Angeles, an intimate gathering in Sequim, or a hosted coastal getaway.</p>
      </div>
      <div class="card">
        <p class="eyebrow">What clients can expect</p>
        <h2>Professionalism with warmth.</h2>
        <ul>
          <li>Custom menus shaped around your preferences, dietary needs, and event goals.</li>
          <li>Seasonal Pacific Northwest inspiration with an eye toward freshness, balance, and elegant presentation.</li>
          <li>Clear communication, reliable timing, and a smooth booking process from inquiry through service.</li>
          <li>Experience serving homes, second residences, and vacation rentals throughout Port Angeles, Sequim, and the Olympic Peninsula.</li>
        </ul>
      </div>
    </div>
  </section>
  <CTA title="Looking for a personal chef who feels polished, responsive, and easy to welcome into your home?" text="Reach out with your date, priorities, and guest experience goals. You’ll receive thoughtful guidance, menu direction, and a tailored proposal." secondaryHref="/services" secondaryLabel="View Services" />
</BaseLayout>
