---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chef Scott Stokes',
  jobTitle: 'Personal Chef',
  worksFor: { '@type': 'LocalBusiness', name: 'Olympic Peninsula Personal Chef' },
  address: { '@type': 'PostalAddress', addressLocality: 'Port Angeles', addressRegion: 'WA' },
  description: 'Chef Scott Stokes offers private dining and personalized meal support across Port Angeles, Sequim, and the Olympic Peninsula with seasonal ingredients, tailored menus, and thoughtful hospitality.'
};
---
<BaseLayout title="About the Chef | Olympic Peninsula Personal Chef" description="Meet the chef behind this Port Angeles and Sequim personal chef service, focused on seasonal ingredients, custom menus, polished hospitality, and a calm client experience." path="/about-the-chef" schema={schema}>
  <section class="section">
    <div class="container grid two-col">
      <div class="card">
        <p class="eyebrow">About the chef</p>
        <h1>A thoughtful, elevated approach to private dining rooted in seasonality, care, and Pacific Northwest hospitality.</h1>
        <p>Chef Scott Stokes brings a thoughtful, elevated approach to private dining on the Olympic Peninsula, shaped by years of hands-on culinary experience, strong hospitality instincts, and a genuine love of creating memorable meals. His work is centered on seasonal ingredients, carefully tailored menus, and the kind of calm, attentive service that helps guests feel cared for from the moment the experience begins.</p>
        <p>Whether preparing a romantic dinner in Port Angeles, a warm gathering in Sequim, or a beautifully planned meal for a coastal getaway, Chef Scott focuses on food that feels both refined and welcoming. His approach blends polished execution with flexibility, allowing each menu to reflect the occasion, the setting, and the people around the table.</p>
        <p>Known for thoughtful menu development, ingredient awareness, and a deep respect for both comfort and quality, Chef Scott creates dining experiences that feel personal rather than performative. From intimate private dinners to customized meal support, the goal is always the same: to serve food with care, intention, and a sense of place rooted in the Pacific Northwest.</p>
      </div>
      <div class="card">
        <p class="eyebrow">What clients can expect</p>
        <h2>Professionalism with warmth.</h2>
        <ul>
          <li>Custom menus shaped around your preferences, dietary needs, and event goals.</li>
          <li>Seasonal Pacific Northwest inspiration with an eye toward freshness, balance, and elegant presentation.</li>
          <li>Clear communication, reliable timing, and a smooth booking process from inquiry through service.</li>
          <li>Experience serving homes, second residences, and vacation rentals throughout Port Angeles, Sequim, and the Olympic Peninsula.</li>
        </ul>
      </div>
    </div>
  </section>
  <CTA title="Looking for a personal chef who feels polished, responsive, and easy to welcome into your home?" text="Reach out with your date, priorities, and guest experience goals. You’ll receive thoughtful guidance, menu direction, and a tailored proposal." secondaryHref="/services" secondaryLabel="View Services" />
</BaseLayout>
