---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MenuCard from '../components/MenuCard.astro';
import CTA from '../components/CTA.astro';
const menus = await getCollection('menus');
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  hasMenuSection: menus.map((menu) => ({ '@type': 'MenuSection', name: menu.data.title, description: menu.data.description }))
};
---
<BaseLayout title="Sample Menus | Private Chef Menus for Port Angeles & Sequim" description="Explore sample menus for Pacific Northwest private dinners, romantic evenings, brunch service, weekly meal prep, and seasonal holiday hosting across the Olympic Peninsula." path="/sample-menus" schema={schema}>
  <section class="section">
    <div class="container split-intro">
      <div class="section-header" style="margin-bottom:0;">
        <p class="eyebrow">Sample menus</p>
        <h1>Menu concepts that feel seasonal, polished, and ready to tailor.</h1>
        <p>These menus are designed to show range rather than lock you into a package. Use them to identify the flavor profile, pacing, and service style that best suits your table.</p>
      </div>
      <div class="info-strip">
        <div><strong>Seasonally informed</strong><span>Menu direction shifts naturally with local produce, seafood, and the time of year.</span></div>
        <div><strong>Built to customize</strong><span>Dietary accommodations and favorite ingredients are welcomed into the planning process.</span></div>
        <div><strong>Useful for planning</strong><span>Perfect for private dinners, vacation weekends, celebrations, and recurring meal routines.</span></div>
      </div>
    </div>
    <div class="container grid two-col" style="margin-top:2rem;">
      {menus.map((menu) => <MenuCard menu={menu} />)}
    </div>
  </section>
  <CTA title="See a menu direction that fits your occasion?" text="Every menu can be refined for guest preferences, dietary needs, wine pairings, seasonal sourcing opportunities, and the overall tone of your event." secondaryHref="/contact" secondaryLabel="Ask About Custom Menus" />
</BaseLayout>
