---
import BaseLayout from '../layouts/BaseLayout.astro';
import { menuBuilderSections, mainCourseOptions, summaryOrder, emptySummaryCopy } from '../data/menuBuilder';
import { withBase } from '../utils/paths';

const pageTitle = 'Your Sample Menu Preview | Olympic Peninsula Personal Chef';
const pageDescription = 'Preview your selected Sample Menu Builder choices in a polished, luxury private-chef menu format.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: `https://YOUR-GITHUB-USERNAME.github.io/PersonalChef/menu-preview/`
};

const dataPayload = {
  sections: menuBuilderSections,
  mainCourseOptions,
  summaryOrder,
  emptySummaryCopy
};
---
<BaseLayout title={pageTitle} description={pageDescription} path="/menu-preview" schema={schema}>
  <section class="section menu-preview-section">
    <div class="container menu-preview-layout">
      <div class="panel menu-preview-intro">
        <p class="eyebrow">Sample menu preview</p>
        <h1>Your Sample Menu</h1>
        <p>
          A preview of your custom menu selections, arranged with the pacing and polish of a composed private-chef dinner.
        </p>
      </div>

      <div class="menu-preview-grid" data-preview-shell>
        <section class="panel menu-preview-card" aria-labelledby="menu-preview-heading" data-preview-filled hidden>
          <div class="menu-preview-card-inner">
            <div class="menu-preview-card-head">
              <div>
                <p class="eyebrow">Composed menu</p>
                <h2 id="menu-preview-heading">Designed for your table</h2>
              </div>
              <span class="menu-preview-badge" data-preview-badge hidden></span>
            </div>

            <div class="menu-preview-lead-wrap">
              <p class="menu-preview-kicker">Chef’s direction</p>
              <p class="menu-preview-lead" data-preview-lead></p>
            </div>

            <div class="menu-preview-course-grid" data-preview-course-grid></div>

            <div class="menu-preview-composed panel-soft">
              <p class="menu-preview-kicker">Composed presentation</p>
              <div class="menu-preview-composed-lines" data-preview-composed-lines></div>
            </div>

            <div class="menu-preview-notes panel-soft" data-preview-notes hidden>
              <p class="menu-preview-kicker">Custom considerations</p>
              <p data-preview-notes-copy></p>
            </div>
          </div>
        </section>

        <aside class="panel menu-preview-sidebar" data-preview-filled hidden>
          <div class="menu-preview-sidebar-head">
            <p class="eyebrow">Next steps</p>
            <h2>Refine or request</h2>
            <p>Make adjustments in the builder or continue to the inquiry flow with your selected menu preserved for Phase 4 handoff.</p>
          </div>

          <div class="menu-preview-actions">
            <a class="btn btn-secondary" href={withBase('/menu-builder')}>Edit My Menu</a>
            <a class="btn btn-primary" href={withBase('/contact?source=menu-preview')} data-submit-menu-request>Submit Menu Request</a>
          </div>

          <div class="menu-preview-sidebar-list panel-soft">
            <p class="menu-preview-kicker">Included in this preview</p>
            <ul>
              <li>Luxury-styled menu composition</li>
              <li>Preserved builder selections</li>
              <li>Phase 4-ready inquiry handoff</li>
            </ul>
          </div>
        </aside>

        <section class="panel menu-preview-empty" data-preview-empty>
          <p class="eyebrow">Build first</p>
          <h2>Your menu preview is waiting.</h2>
          <p>
            Start in the Sample Menu Builder to select your dining style, courses, and finishing details. Once choices are made,
            they’ll appear here in a polished preview.
          </p>
          <div class="menu-preview-actions">
            <a class="btn btn-primary" href={withBase('/menu-builder')}>Go to Menu Builder</a>
            <a class="btn btn-secondary" href={withBase('/sample-menus')}>Browse Sample Menus</a>
          </div>
        </section>
      </div>
    </div>
  </section>

  <script type="application/json" id="menu-preview-data" set:html={JSON.stringify(dataPayload)}></script>
  <script type="module">
    import {
      buildMenuRequestMessage,
      getComposedMenuPreview,
      getOptionLabel,
      previewLabels,
      previewSectionOrder,
      readBuilderState,
      storeMenuRequestPayload,
      summaryLabels
    } from '../utils/menuBuilderClient';

    const dataElement = document.getElementById('menu-preview-data');

    if (dataElement?.textContent) {
      const builderData = JSON.parse(dataElement.textContent);
      const state = readBuilderState();
      const emptyState = document.querySelector('[data-preview-empty]');
      const filledSections = document.querySelectorAll('[data-preview-filled]');
      const courseGrid = document.querySelector('[data-preview-course-grid]');
      const composedLines = document.querySelector('[data-preview-composed-lines]');
      const notesPanel = document.querySelector('[data-preview-notes]');
      const notesCopy = document.querySelector('[data-preview-notes-copy]');
      const badge = document.querySelector('[data-preview-badge]');
      const lead = document.querySelector('[data-preview-lead]');
      const submitButton = document.querySelector('[data-submit-menu-request]');

      const hasSelections = previewSectionOrder.some((sectionId) => {
        if (sectionId === 'optionalAdditions') return state.optionalAdditions.length > 0;
        if (sectionId === 'customConsiderations') return Boolean(state.customConsiderations.trim());
        return Boolean(state[sectionId]);
      });

      if (!hasSelections) {
        filledSections.forEach((section) => {
          section.hidden = true;
        });
      } else {
        emptyState?.setAttribute('hidden', 'true');
        filledSections.forEach((section) => {
          section.hidden = false;
        });

        const preview = getComposedMenuPreview(builderData, state);

        if (badge && preview.diningStyle) {
          badge.textContent = preview.diningStyle;
          badge.hidden = false;
        }

        if (lead) {
          lead.textContent = preview.lead;
        }

        if (courseGrid) {
          const cards = previewSectionOrder
            .map((sectionId) => {
              if (sectionId === 'optionalAdditions') {
                if (!state.optionalAdditions.length) return null;
                return {
                  label: previewLabels.optionalAdditions,
                  value: state.optionalAdditions
                    .map((value) => getOptionLabel(builderData, state, 'optionalAdditions', value))
                    .filter(Boolean)
                    .join(' · ')
                };
              }

              if (sectionId === 'customConsiderations') {
                return null;
              }

              const value = state[sectionId];
              if (!value) return null;

              return {
                label: summaryLabels[sectionId] || sectionId,
                value: getOptionLabel(builderData, state, sectionId, value)
              };
            })
            .filter(Boolean);

          courseGrid.innerHTML = cards.map((item) => `
            <article class="menu-preview-detail-card">
              <p>${item.label}</p>
              <strong>${item.value}</strong>
            </article>
          `).join('');
        }

        if (composedLines) {
          composedLines.innerHTML = preview.composedLines.map((item) => `
            <article class="menu-preview-composed-line">
              <p>${item.label}</p>
              <strong>${item.value}</strong>
              ${item.description ? `<span>${item.description}</span>` : ''}
            </article>
          `).join('');
        }

        if (notesPanel && notesCopy && preview.details.customConsiderations) {
          notesPanel.hidden = false;
          notesCopy.textContent = preview.details.customConsiderations;
        }

        submitButton?.addEventListener('click', () => {
          storeMenuRequestPayload({
            source: 'menu-preview',
            state,
            summary: buildMenuRequestMessage(builderData, state),
            savedAt: new Date().toISOString()
          });
        });
      }
    }
  </script>
</BaseLayout>
