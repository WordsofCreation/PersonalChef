---
import type { CollectionEntry } from 'astro:content';
const { testimonial } = Astro.props as { testimonial: CollectionEntry<'testimonials'> };
---
<article class="card">
  <p>{'★'.repeat(testimonial.data.rating)}</p>
  <p class="quote">“{testimonial.data.quote}”</p>
  <p><strong>{testimonial.data.name}</strong> · {testimonial.data.location}</p>
  <p>{testimonial.data.service}</p>
</article>
