---
interface Option {
  value: string;
  label: string;
  description?: string;
}

interface Props {
  sectionId: string;
  options: Option[];
  type: 'single' | 'multiple';
}

const { sectionId, options, type } = Astro.props;
const formatCardId = (optionValue: string) => `${sectionId}-${optionValue}`;
---
{options.map((option) => (
  <label class="builder-option" for={formatCardId(option.value)} data-option-card data-section={sectionId} data-value={option.value}>
    <input
      id={formatCardId(option.value)}
      class="builder-option-input"
      type={type === 'multiple' ? 'checkbox' : 'radio'}
      name={sectionId}
      value={option.value}
      data-builder-input
      data-section={sectionId}
    />
    <span class="builder-option-check" aria-hidden="true"></span>
    <span class="builder-option-copy">
      <strong>{option.label}</strong>
      {option.description && <span>{option.description}</span>}
    </span>
  </label>
))}
